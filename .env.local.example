# ------------------------------------------------------------
# Sanity
# ------------------------------------------------------------

# Secreto para validar el webhook de revalidación ISR (/api/revalidate).
# Generar uno fresco con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# El MISMO valor va en 3 sitios:
#   1. Este fichero (.env.local) — para que funcione en dev local.
#   2. Vercel → Project → Settings → Environment Variables (Production + Preview + Development).
#   3. Sanity manage.sanity.io → gdtxcn4l → API → Webhooks → como query string
#      `?secret=<valor>` en la URL de destino (ej: https://ebecerra.es/api/revalidate?secret=...).
SANITY_REVALIDATE_SECRET=your-secret-here

# Token de escritura de Sanity (solo necesario si usas server-side mutations).
# Para lectura anónima con useCdn:true no hace falta.
# SANITY_API_TOKEN=your-write-token-here


# ------------------------------------------------------------
# Resend (form de contacto /api/contact — se activa en Fase 11)
# ------------------------------------------------------------

# API key generada en resend.com → API Keys.
# Es secreta: no la comites ni la compartas.
# En Vercel también va en las 3 environments (Production + Preview + Development).
RESEND_API_KEY=re_xxx

# Destinatario del form de contacto.
# En dev puedes poner tu email personal para no spamear la bandeja real;
# en producción (Vercel) apunta a contacto@ebecerra.es.
# Si no defines esta var, /api/contact usa "contacto@ebecerra.es" por defecto.
CONTACT_TO_EMAIL=contacto@ebecerra.es
