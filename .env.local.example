# Secreto compartido entre Vercel (env var) y el webhook de Sanity Studio.
# Generar uno fresco con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Luego el MISMO valor va en 3 sitios:
#   1. Este fichero (.env.local) — para que /api/revalidate funcione en dev local.
#   2. Vercel → Project → Settings → Environment Variables (Production + Preview + Development).
#   3. Sanity manage.sanity.io → gdtxcn4l → API → Webhooks → como query string
#      `?secret=<valor>` en la URL de destino (ej: https://ebecerra.es/api/revalidate?secret=...).
SANITY_REVALIDATE_SECRET=your-secret-here

# Sanity write token (solo necesario si usas server-side mutations)
# SANITY_API_TOKEN=your-write-token-here

# Resend API key (se activa en Fase 11 al sustituir Formspree por /api/contact)
# RESEND_API_KEY=re_xxx

# Destinatario del form de contacto (se activa con Resend)
# CONTACT_TO_EMAIL=contacto@ebecerra.es
